# Database
DATABASE_URL=postgresql://user:password@host:5432/radar_blog

# NextAuth
NEXTAUTH_URL=https://radarlog.kr
NEXTAUTH_SECRET=your-secret-key-here
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Git OAuth
# https://github.com/settings/applications/new
#Homepage URL: https://radarlog.kr
#Callback URL: https://radarlog.kr/api/auth/callback/github

# GitHub Token → 여기서 repo 권한으로 발급
# # https://github.com/settings/tokens
# GITHUB_WEBHOOK_SECRET → 아무 랜덤 문자열이나 (나중에 GitHub Webhook 설정 시 동일하게 입력)

# Automatic writing (cron/webhook) is disabled unless explicitly enabled.
AUTO_WRITING_ENABLED=false

# AI Provider (OpenAI-compatible endpoint)
# Custom proxy (OpenClaw, OhMyCode 등) 사용 시:
#   AI_BASE_URL=https://your-proxy-service.com/v1
#   AI_API_KEY=your-session-token
#   AI_MODEL=claude-sonnet-4-20250514
# 이 값들이 설정되면 Admin에서 선택한 프로바이더보다 우선 적용됨
AI_BASE_URL=
AI_API_KEY=
AI_MODEL=

# Provider-specific keys (AI_API_KEY 미설정 시 Admin 선택 프로바이더의 키 사용)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
XAI_API_KEY=
GOOGLE_AI_API_KEY=

# Gemini (thumbnail generation)
GEMINI_API_KEY=

# GitHub (for Octokit)
GITHUB_TOKEN=
GITHUB_WEBHOOK_SECRET=

# Admin
ADMIN_GITHUB_ID=your-github-username

# Umami (통계)
NEXT_PUBLIC_UMAMI_URL=https://your-umami.railway.app
NEXT_PUBLIC_UMAMI_WEBSITE_ID=
