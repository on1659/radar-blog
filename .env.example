# Database
DATABASE_URL=postgresql://user:password@host:5432/radar_blog

# NextAuth
NEXTAUTH_URL=https://your-domain.com
NEXTAUTH_SECRET=your-secret-key-here
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Git OAuth
# https://github.com/settings/applications/new
#Homepage URL: https://radar-blog.railway.app (배포 후 도메인)
#Callback URL: https://radar-blog.railway.app/api/auth/callback/github

# GitHub Token → 여기서 repo 권한으로 발급
# # https://github.com/settings/tokens
# GITHUB_WEBHOOK_SECRET → 아무 랜덤 문자열이나 (나중에 GitHub Webhook 설정 시 동일하게 입력)

# Z.ai API
Z_AI_API_KEY=

# GitHub (for Octokit)
GITHUB_TOKEN=
GITHUB_WEBHOOK_SECRET=

# Admin
ADMIN_GITHUB_ID=your-github-username

# Umami (통계)
NEXT_PUBLIC_UMAMI_URL=https://your-umami.railway.app
NEXT_PUBLIC_UMAMI_WEBSITE_ID=
