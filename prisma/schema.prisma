generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Post {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  titleEn     String?
  subtitle    String?
  content     String
  contentEn   String?
  excerpt     String?
  excerptEn   String?
  category    Category
  coverImage     String?
  thumbnailData  String?   // base64 encoded thumbnail image
  published      Boolean  @default(false)
  featured    Boolean  @default(false)
  readingTime Int      @default(0)
  tags        String[]
  locale      String   @default("ko")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Commit 관련 필드
  commitHash       String?
  commitUrl        String?
  repoName         String?
  projectSlug      String?
  filesChanged     Int?

  // 시리즈 관련
  series      Series?  @relation(fields: [seriesId], references: [id])
  seriesId    String?
  seriesOrder Int?

  // 조회수
  viewCount      Int      @default(0)
  botViewCount   Int      @default(0)
  analytics      DailyAnalytics[]

  @@index([category])
  @@index([published])
  @@index([createdAt])
  @@index([projectSlug])
}

model Series {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  description String?
  posts       Post[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ApiKey {
  id        String   @id @default(cuid())
  name      String
  key       String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  lastUsed  DateTime?
}

model WatchedRepo {
  id              String   @id @default(cuid())
  owner           String
  name            String
  branch          String   @default("main")
  active          Boolean  @default(true)
  autoPublish     Boolean  @default(false)
  promptTemplate  String?
  categoryMapping String?
  githubHookId    Int?
  createdAt       DateTime @default(now())

  @@unique([owner, name])
}

model DailyAnalytics {
  id     String   @id @default(cuid())
  postId String
  post   Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  date     DateTime @db.Date
  views    Int      @default(0)
  botViews Int      @default(0)

  @@unique([postId, date])
  @@index([date])
  @@index([postId])
}

model Project {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  icon        String   @default("📦")
  gradient    String   @default("from-[#3182F6] to-[#1D4ED8]")
  tags        String[]
  githubUrl   String?
  deployUrl   String?
  order       Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([order])
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

enum Category {
  commits
  articles
  casual
  signal
}
